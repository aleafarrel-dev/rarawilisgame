---
import BaseLayout from './BaseLayout.astro';
import { VolumeControl } from '../components/puzzle/VolumeControl';

interface Props {
  title: string;
  pageTitle?: string;
  backUrl?: string; // If provided, shows back button instead of home
  homeUrl?: string; // Default is /menu
}

const { title, pageTitle, backUrl, homeUrl = '/menu' } = Astro.props;
---

<BaseLayout title={title}>
  <div class="page-wrapper">
    <nav class="top-nav">
      <VolumeControl client:load />
      {backUrl ? (
        <a href={backUrl} class="nav-btn btn-home" aria-label="Back">
          <img src="/assets/button/home-button.png" alt="Back" />
        </a>
      ) : (
        <a href={homeUrl} class="nav-btn btn-home" aria-label="Home">
          <img src="/assets/button/home-button.png" alt="Home" />
        </a>
      )}
    </nav>
    
    {pageTitle && <h1 class="page-title">{pageTitle}</h1>}
    
    <slot />
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }
</style>
