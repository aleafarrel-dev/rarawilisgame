---
import PageLayout from "../../layouts/PageLayout.astro";
---

<PageLayout title="Profil Pengembang" pageTitle="PROFIL PENGEMBANG">
  <main class="profil-screen">


    <div class="profiles-container">
      <div class="profile-card">
        <img
          src="/assets/icon/profile-icon-1.png"
          alt="Dr. Wahyu Purwaningsih, M.Pd."
          class="profile-img"
        />
        <h2 class="profile-name">Dr. Wahyu Purwaningsih, M.Pd.</h2>
      </div>

      <div class="profile-card">
        <img
          src="/assets/icon/profile-icon-2.png"
          alt="Rara Wilis"
          class="profile-img"
        />
        <h2 class="profile-name">Rara Wilis</h2>
      </div>
    </div>

    <a href="/profil/dr-wahyu" class="nav-btn btn-next" aria-label="Next">
      <img src="/assets/button/next-button.png" alt="Next" />
    </a>
  </main>
</PageLayout>

<style>
  .profil-screen {
    width: 100%;
    min-height: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
    padding-top: 5cqh;
  }

  .profiles-container {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    gap: 8cqw;
    width: 100%;
    margin-left: -5cqw;
    margin-top: 25cqh;
  }

  .profile-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: flex-end;
    width: max-content;
  }

  .profile-img {
    width: 17cqw;
    height: auto;
    object-fit: contain;
    margin-bottom: 2.5cqh;
    filter: drop-shadow(0 0.5cqw 0 rgba(0, 0, 0, 0.1));
  }

  .profile-name {
    font-size: 2.5cqw;
    font-weight: 900;
    color: var(--color-text-heading);
    text-align: center;
    margin: 0;
    white-space: nowrap;
    line-height: 1.3;
  }

  .btn-next {
    position: absolute;
    bottom: 2cqh;
    right: 3cqw;
    z-index: 20;
  }
</style>
