---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Main">
  <main class="splash-screen">
    <img src="/assets/logo/tut-wuri-handayani.png" alt="Tut Wuri Handayani" class="logo logo-left" />
    <img src="/assets/logo/diktisanintek.png" alt="Diktisaintek" class="logo logo-right" />
    
    <div class="center-content">
      <h1 class="game-title">
        Multimedia Pembelajaran<br/>Matematika
      </h1>
      
      <a href="/biodata" class="btn-play">
        <img src="/assets/button/start-button.png" alt="Start Game" />
      </a>
    </div>

    <img src="/assets/images/decoration-thinking.png" alt="Student studying left" class="deco-img deco-left" />
    <img src="/assets/images/decoration-thinking.png" alt="Student studying right" class="deco-img deco-right" />
  </main>
</BaseLayout>

<style>
  .splash-screen {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }

  .logo {
    position: absolute;
    top: 5cqh;
    height: auto;
    max-height: 15cqh;
    z-index: 10;
  }
  .logo-left { left: 8cqw; }
  .logo-right { right: 8cqw; }

  .center-content {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    z-index: 5;
    padding: 28cqh 0 8cqh 0;
  }

  .game-title {
    font-size: 6.5cqw;
    color: var(--color-text-heading);
    text-align: center;
    line-height: 1.2;
    text-shadow: 0.3cqw 0.3cqw 0 #fff, -0.3cqw -0.3cqw 0 #fff, 0.3cqw -0.3cqw 0 #fff, -0.3cqw 0.3cqw 0 #fff,
                 0px 0.3cqw 0 #fff, 0px -0.3cqw 0 #fff, 0.3cqw 0px 0 #fff, -0.3cqw 0px 0 #fff;
  }

  .btn-play {
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  
  .btn-play img {
    width: 20cqw;
    height: auto;
  }

  .btn-play:hover { transform: scale(1.05); }
  .btn-play:active { transform: scale(0.95); }

  .deco-img {
    position: absolute;
    bottom: 5cqh;
    width: 18cqw;
    height: auto;
    z-index: 1;
    pointer-events: none;
  }
  .deco-left { left: 15cqw; }
  .deco-right { right: 15cqw; }
</style>
