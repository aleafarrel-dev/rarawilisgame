---
import PageLayout from "../layouts/PageLayout.astro";
---

<PageLayout title="Menu Utama" homeUrl="/">
  <main class="menu-screen">
    <div class="menu-container">
      <h1 class="menu-title">
        <span class="title-huge">AYOO!!!</span><br />
        KITA BELAJAR LUAS BANGUN DATAR<br />
        (PERSEGI DAN PERSEGI PANJANG<br />
        BERSAMA)
      </h1>

      <div class="menu-rows">
        <!-- ROW 1 -->
        <div class="menu-row">
          <a href="/petunjuk" class="menu-card">
            <div class="rings">
              <div class="ring"></div><div class="ring"></div><div class="ring">
              </div><div class="ring"></div>
            </div>
            <div class="card-content">
              <img
                src="/assets/icon/menu-icon-book.png"
                alt="Petunjuk"
                class="card-icon"
              />
              <span class="card-text">PETUNJUK</span>
            </div>
          </a>

          <a href="/profil" class="menu-card">
            <div class="rings">
              <div class="ring"></div><div class="ring"></div><div class="ring">
              </div><div class="ring"></div>
            </div>
            <div class="card-content">
              <img
                src="/assets/icon/menu-icon-profile.png"
                alt="Profil"
                class="card-icon"
              />
              <span class="card-text">PROFIL</span>
            </div>
          </a>

          <a href="/tujuan" class="menu-card">
            <div class="rings">
              <div class="ring"></div><div class="ring"></div><div class="ring">
              </div><div class="ring"></div>
            </div>
            <div class="card-content">
              <img
                src="/assets/icon/menu-icon-objective.png"
                alt="Tujuan"
                class="card-icon"
              />
              <span class="card-text">TUJUAN</span>
            </div>
          </a>
        </div>

        <!-- ROW 2 -->
        <div class="menu-row">
          <a href="/latihan" class="menu-card">
            <div class="rings">
              <div class="ring"></div><div class="ring"></div><div class="ring">
              </div><div class="ring"></div>
            </div>
            <div class="card-content">
              <img
                src="/assets/icon/menu-icon-brain.png"
                alt="Latihan"
                class="card-icon"
              />
              <span class="card-text">LATIHAN</span>
            </div>
          </a>

          <a href="/puzzle" class="menu-card">
            <div class="rings">
              <div class="ring"></div><div class="ring"></div><div class="ring">
              </div><div class="ring"></div>
            </div>
            <div class="card-content">
              <img
                src="/assets/icon/menu-icon-puzzle.png"
                alt="Puzzle"
                class="card-icon"
              />
              <span class="card-text">Puzzle</span>
            </div>
          </a>
        </div>
      </div>

      <img src="/assets/icon/star.png" class="sparkle s1" alt="" />
      <img src="/assets/icon/star.png" class="sparkle s2" alt="" />
      <img src="/assets/icon/star.png" class="sparkle s3" alt="" />
      <img src="/assets/icon/star.png" class="sparkle s4" alt="" />
    </div>
  </main>
</PageLayout>

<style>
  .menu-screen {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 2rem;
  }

  .menu-container {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: -12cqh;
    position: relative;
  }

  .menu-title {
    font-size: 3cqw;
    text-align: center;
    margin-bottom: 8cqh;
    color: var(--color-text-heading);
    line-height: 1.3;
    font-weight: 900;
  }

  .title-huge {
    font-size: 6cqw;
  }

  .menu-rows {
    display: flex;
    flex-direction: column;
    gap: 6cqh;
    align-items: center;
    width: 100%;
    z-index: 2;
  }

  .menu-row {
    display: flex;
    justify-content: center;
    gap: 3cqw;
  }

  .menu-card {
    position: relative;
    background-color: #d8f3fd;
    border: 0.2cqw solid #1b263b;
    border-radius: 1.5cqw;
    text-decoration: none;
    box-shadow:
      0.5cqw 0.5cqw 0 #fff,
      0.5cqw 0.5cqw 0 0.2cqw #1b263b;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    min-width: 22cqw;
    height: 7cqw;
  }

  .menu-card:hover {
    transform: translateY(-4px) scale(1.02);
  }
  .menu-card:active {
    transform: translateY(2px) scale(0.98);
  }

  .rings {
    position: absolute;
    top: -0.6cqw;
    left: 0;
    width: 100%;
    display: flex;
    justify-content: center;
    gap: 1.5cqw;
  }

  .ring {
    width: 1.2cqw;
    height: 1.2cqw;
    border-radius: 50%;
    background-color: #fff;
    border: 0.2cqw solid #1b263b;
  }

  .card-content {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    padding: 0 2cqw;
  }

  .card-icon {
    height: 3.5cqw;
    width: auto;
    object-fit: contain;
    margin-right: 1cqw;
  }

  .card-text {
    font-size: 2.8cqw;
    font-weight: 900;
    color: var(--color-text-heading);
  }

  .sparkle {
    position: absolute;
    width: 3cqw;
    height: auto;
    z-index: 1;
  }

  .s1 {
    top: 38%;
    left: 10%;
    width: 4cqw;
  }
  .s2 {
    top: 35%;
    right: 12%;
    width: 2.5cqw;
  }
  .s3 {
    bottom: 8%;
    left: 20%;
    width: 3cqw;
  }
  .s4 {
    bottom: 15%;
    right: 15%;
    width: 3.5cqw;
  }
</style>
